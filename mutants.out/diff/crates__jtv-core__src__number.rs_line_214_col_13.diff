     // Check if value is truthy (for conditionals)
     pub fn is_truthy(&self) -> bool {
         match self {
-            Value::Bool(b) => *b,
+             /* ~ changed by cargo-mutants ~ */
             Value::Int(n) => *n != 0,
             Value::Float(f) => *f != 0.0,
             Value::Rational(r) => !r.is_zero(),
             Value::String(s) => !s.is_empty(),
             Value::List(l) => !l.is_empty(),
             Value::Unit => false,
             _ => true,
         }
