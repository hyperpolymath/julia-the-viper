 fn parse_reversible_stmt(pair: pest::iterators::Pair<Rule>) -> Result<ReversibleStmt> {
     let inner = pair.into_inner().next().unwrap();
 
     match inner.as_rule() {
         Rule::reversible_assignment => {
             let mut parts = inner.into_inner();
