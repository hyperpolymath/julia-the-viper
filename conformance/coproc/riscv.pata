//
// Companion PataCL source for JtV coproc conformance fixtures.
// Mirrors the RISC-V gates from patacl/conformance/riscv.pata.

pata v1

gate riscv_vec  when arch == "riscv64" && feature_v
family riscv_vec = "riscv"

gate zbb        when arch == "riscv64" && feature_zbb
family zbb = "riscv"

gate riscv_any  when arch == "riscv64" || arch == "riscv32"
family riscv_any = "riscv"
