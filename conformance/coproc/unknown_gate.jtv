// JtV coproc conformance: gate name absent from pata → build error.
//
// Companion pata: unknown_gate.pata  (defines "some_other_gate", not "mystery_ext")
// Target:         riscv64gc-unknown-none-elf
// Expected:       CoprocResolutionFailed { gate: "mystery_ext" }

extern coproc mystery_ext {
    @pure intrinsic do_magic(a: Int): Int ;
}
